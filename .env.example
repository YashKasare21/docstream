# DocStream Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ─── AI API Keys ──────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional Settings ────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
DOCSTREAM_LOG_LEVEL=INFO

# Maximum file size in bytes (default: 52428800 = 50MB)
DOCSTREAM_MAX_FILE_SIZE=52428800

# LaTeX engine: pdflatex, xelatex, lualatex
DOCSTREAM_LATEX_ENGINE=pdflatex
